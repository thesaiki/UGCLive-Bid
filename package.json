{
  "name": "ugclive-bid",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  },
  "scripts": {
    "dev:web": "npm --workspace @ugclive/web run dev",
    "dev:api": "npm --workspace @ugclive/api run dev",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces"
  }
}
